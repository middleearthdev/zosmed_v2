# Zosmed environment variables (ADR-002 — Instagram API with Instagram Login).
# Copy to .env and fill in real values. Never commit a real .env file.

# ── Postgres / Redis ──────────────────────────────────────────────────────────
DB_URL=postgresql://zosmed:zosmed@localhost:5432/zosmed?sslmode=disable
REDIS_URL=redis://localhost:6379

# ── Instagram Login (Business Login for Instagram, CLAUDE.md §4.0) ───────────
# All four are required at startup for both apps/api and apps/worker.
#
# IG_APP_ID / IG_APP_SECRET come from the Meta App Dashboard, product
# "Instagram" (NOT "Facebook Login"/"Messenger"). IG_APP_SECRET is one value
# shared by three purposes (DRY — one App, one secret):
#   1. OAuth client_secret (code/token exchange, apps/api/internal/connect)
#   2. HMAC-SHA256 verification of X-Hub-Signature-256 webhook payloads
#   3. Signing the connect-flow anti-CSRF state parameter
IG_APP_ID=
IG_APP_SECRET=
# IG_VERIFY_TOKEN is the arbitrary string you also enter in the Meta App
# Dashboard's webhook subscription screen (GET /webhooks/meta handshake).
IG_VERIFY_TOKEN=
# Must match EXACTLY (including scheme, host, path, trailing slash) the
# "Valid OAuth Redirect URI" registered for the Instagram product.
IG_REDIRECT_URI=https://api.zosmed.example.com/connect/instagram/callback

# ── WhatsApp handoff (wa.me deep link, no API — CLAUDE.md §4/§7) ─────────────
WA_PHONE=6281234567890

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=8080
